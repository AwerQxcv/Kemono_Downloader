{
  "manifest_version": 2,
  "name": "Kemono_Downloader",
  "description": "__MSG_manifest_description__",
  "version": "1.2.5",
  "default_locale": "en",
  "author": "AwerQxcv",
  "icons": {
    "48": "icon_48.png",
    "96": "icon_96.png",
    "128": "icon_128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://kemono.cr/*"],
      "js": ["Kemono_Downloader.js"]
    }
  ],
  "background": {
    "scripts": ["event_page.js"]
  },
  "commands": {
    "download": {
      "suggested_key": {
        "default": "Ctrl+Shift+F"
      },
      "description": "__MSG_manifest_shortcut_desc__"
    }
  },
  "permissions": [
    "downloads",
    "storage",
    "tabs",
    "contextMenus",
    "notifications",
    "*://kemono.cr/*"
  ],
  "web_accessible_resources": ["icon.svg"],
  "browser_action": {
    "default_icon": "icon_48.png",
    "default_title": "__MSG_manifest_download_options__",
    "default_popup": "popup.html"
  },
  "options_ui": {
    "page": "settings.html"
  },
  "homepage_url": "https://awerqxcv.github.io/Kemono_Downloader/"
}
